# Copy to .env and fill in your values — never commit .env to source control

# Alpaca
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Alpha Vantage
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key

# TimescaleDB — matches docker-compose defaults
DB_URL=postgresql+psycopg2://trader:traderpass@localhost:5432/trading

# Logging
LOG_LEVEL=INFO

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4

# Docker Compose overrides (optional)
POSTGRES_USER=trader
POSTGRES_PASSWORD=traderpass
POSTGRES_DB=trading
